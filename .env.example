NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL pubblica (invite email redirect, es. https://hub.reparto.it — aggiungi anche tra Redirect URLs nel pannello Supabase Auth).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opzionale: intestazione PDF turni mensili (scuola / reparto), mostrata nell’header del documento.
# NEXT_PUBLIC_PLANNING_ORG_LABEL=Scuola di specializzazione in Anestesia e Rianimazione — A.O.U. …

# --- Test E2E Playwright (non committare credenziali reali; usare utenti dedicati o .env.local) ---
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_START_SERVER=1
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# E2E_SPECIALIZZANDO_EMAIL=
# E2E_SPECIALIZZANDO_PASSWORD=
# Per test Playwright Ferie seriali: cleanup su 2026-07-15 (service role già sopra).
