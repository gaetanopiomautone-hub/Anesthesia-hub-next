{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/archivio/download/[id]",
      "regex": "^/archivio/download/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/archivio/download/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/archivio",
      "regex": "^/archivio(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/archivio(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/ferie",
      "regex": "^/ferie(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ferie(?:/)?$"
    },
    {
      "page": "/forbidden",
      "regex": "^/forbidden(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/forbidden(?:/)?$"
    },
    {
      "page": "/logbook",
      "regex": "^/logbook(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/logbook(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/report",
      "regex": "^/report(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/report(?:/)?$"
    },
    {
      "page": "/turni",
      "regex": "^/turni(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/turni(?:/)?$"
    },
    {
      "page": "/turni-ferie",
      "regex": "^/turni\\-ferie(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/turni\\-ferie(?:/)?$"
    },
    {
      "page": "/universita",
      "regex": "^/universita(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/universita(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}